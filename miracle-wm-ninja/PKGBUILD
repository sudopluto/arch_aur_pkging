# Contributor: twa022 <twa022 at gmail dot com>

pkgname=miracle-wm-ninja
pkgver=0.9.0
pkgrel=1
pkgdesc="Wayland compositor based on mir"
arch=('i686' 'x86_64' 'armv7h' 'aarch64')
url="https://github.com/miracle-wm-org/miracle-wm"
license=('GPL-3.0-or-later')
depends=('mir'
         # implicit depends
         'libglvnd' 'yaml-cpp' 'bash' 'json-c' 'libgcc' 'libstdc++' 'glib2' 'pcre2' 'glibc' 'wayland'
         'python' 'python-tenacity' 'python-dbus-next'
         'libxkbcommon'
    )
makedepends=('cmake' 'nlohmann-json' 'ninja' 'glm' 'boost')
provides=('miracle-wm')
conflicts=('miracle-wm')
source=("${pkgname%-ninja}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('b22fcd05033812c4ee505bc29a882c41d61eaa67469a3e0422ea76fff2702f05')

prepare() {
    sed -i 's/python3/python/g' $srcdir/${pkgname%-ninja}-${pkgver}/session/usr/bin/libexec/miracle-wm-wait-sni-ready
    sed -i 's/python3/python/g' $srcdir/${pkgname%-ninja}-${pkgver}/tools/check_license.py
}

build() {

    local _flags=(
        -B build 
        -S "${pkgname%-ninja}-${pkgver}" 
        -GNinja
        -Wno-dev
        -DCMAKE_BUILD_TYPE=None
        -DCMAKE_INSTALL_PREFIX=/usr
        -DCMAKE_INSTALL_LIBDIR=lib
        # miracle-wm options
        -DCMAKE_INSTALL_LIBEXECDIR=/usr/lib/$pkgname/
        -DSYSTEMD_INTEGRATION=ON
        -DFEATURE_PLUGIN_SYSTEM=OFF
    )

    cmake "${_flags[@]}"
    cmake --build build
}

package() {
  DESTDIR="${pkgdir}" cmake --install build
}
